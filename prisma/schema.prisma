generator client {
  provider = "prisma-client-js"
}

// Prisma 7: url is no longer in schema.prisma — it lives in prisma.config.ts
// Runtime client uses @prisma/adapter-pg (see src/lib/db/index.ts)
datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum UserRole {
  Admin
  Manager
  Cashier
  Technician
}

enum SubscriptionStatus {
  trial
  active
  grace
  read_only
  cancelled
  suspended
}

enum PaymentModel {
  yearly
  lifetime
}

enum PlanCode {
  trial
  single_store
  multi_store
}

enum CustomerType {
  named
  walkin
}

enum LanguagePreference {
  fr
  ar
  en
}

enum DebtTransactionType {
  repair_debt
  sale_debt
  manual_debt
  payment
  adjustment
  opening_balance
}

enum DebtDirection {
  debit
  credit
}

// Connector types for device models (used in catalog — Block 6)
enum ConnectorType {
  lightning
  usb_c
  micro_usb
  other
  unknown
}

// Document sequence types for ticket/invoice numbering
enum DocumentSequenceType {
  ticket
  invoice
  estimate
  purchase_invoice
  refund
  tradein
  pos_sale
}

// Repair Ticket Enums
enum RepairStatus {
  received
  in_diagnosis
  waiting_customer_approval
  in_repair
  ready_for_pickup
  completed
  not_repaired
}

enum RepairPriority {
  normal
  rush
}

enum ProblemResolutionStatus {
  pending
  fixed
  not_fixed
  deferred
}

// Estimate Enums
enum EstimateStatus {
  draft
  sent
  accepted
  rejected
  converted_to_invoice
}

enum EstimateLineType {
  labor
  part
  service
  custom
}

enum CustomerApprovalMethod {
  phone
  in_person
  whatsapp_reply
  other
}

// Repair Part Reservation Enums
enum RepairPartStatus {
  reserved
  released
  used
}

// Cash Register Enums
enum CashSessionStatus {
  opened
  closed
  force_closed
}

// POS Sale Enums
enum PosSaleStatus {
  completed
  cancelled
}

// Repair Invoice Enums
enum RepairInvoiceStatus {
  unpaid
  partial
  paid
  cancelled
}

enum CashMovementType {
  opening
  pos_sale
  repair_payment
  debt_payment
  refund
  expense
  correction
}

enum CashMovementDirection {
  in
  out
}

enum CatalogSuggestionStatus {
  pending
  approved
  rejected
  merged
}

// ─────────────────────────────────────────────────────────────────────────────
// TENANT & AUTH
// ─────────────────────────────────────────────────────────────────────────────

model Company {
  id         String   @id @default(cuid())
  name       String
  address    String?
  phone      String?
  email      String?
  logoUrl    String?
  isArchived Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  stores                Store[]
  users                 User[]
  subscriptions         CompanySubscription[]
  customerGroups        CustomerGroup[]
  customers             Customer[]
  // Denormalized back-relation for phone uniqueness per company
  customerPhones        CustomerPhone[]
  auditLogs             AuditLog[]
  impersonationSessions TenantImpersonationSession[]
  suppliers             Supplier[]
  purchaseInvoices      PurchaseInvoice[]
  purchaseOrders        PurchaseOrder[]
  stockBatches          StockBatch[]
  stockMovements        StockMovement[]
  repairTickets         RepairTicket[]
  estimates             Estimate[]
  customerApprovalLogs  CustomerApprovalLog[]
  cashSessions          CashRegisterSession[]
  posSales              PosSale[]
  cashMovements         CashMovement[]
  repairInvoices        RepairInvoice[]
  refunds               Refund[]


  @@index([name])
  @@map("companies")
}

model SuperAdminUser {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  impersonationSessions TenantImpersonationSession[]
  auditLogs             AuditLog[]

  @@map("super_admin_users")
}

model User {
  id                 String             @id @default(cuid())
  companyId          String
  name               String
  email              String
  passwordHash       String
  // 4-digit manager PIN for in-shop approval flows (bcrypt hashed)
  pinHash            String?
  role               UserRole
  languagePreference LanguagePreference @default(fr)
  isActive           Boolean            @default(true)
  isArchived         Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  company       Company           @relation(fields: [companyId], references: [id])
  storeAccess   UserStoreAccess[]
  refreshTokens         RefreshToken[]
  auditLogs             AuditLog[]
  purchaseInvoicesCreated PurchaseInvoice[]
  stockMovementsCreated   StockMovement[]
  repairsAssigned         RepairTicket[] @relation("AssignedRepairs")
  repairsCreated          RepairTicket[] @relation("CreatedRepairs")
  repairStatusChanges     RepairStatusHistory[]
  createdEstimates        Estimate[]
  confirmedApprovals      CustomerApprovalLog[]
  reservedParts           RepairTicketPart[] @relation("ReservedByUser")
  releasedParts           RepairTicketPart[] @relation("ReleasedByUser")
  openedCashSessions      CashRegisterSession[] @relation("CashSessionOpenedBy")
  closedCashSessions      CashRegisterSession[] @relation("CashSessionClosedBy")
  forceClosedCashSessions CashRegisterSession[] @relation("CashSessionForceClosedBy")
  posSalesCreated         PosSale[]
  cashMovementsCreated    CashMovement[]
  repairInvoicesCreated   RepairInvoice[] @relation("RepairInvoicesCreated")
  refundsCreated          Refund[]
  expensesCreated         Expense[] @relation("ExpensesCreated")
  purchaseOrdersCreated    PurchaseOrder[] @relation("PurchaseOrdersCreated")


  @@unique([companyId, email])
  @@index([companyId, role])
  @@map("users")
}

model Store {
  id                String   @id @default(cuid())
  companyId         String
  // prefix is used in document numbers: e.g. "ALG-2025-11-0042"
  name              String
  prefix            String
  address           String?
  phone             String?
  email             String?
  logoUrl           String?
  businessHoursJson Json?
  isActive          Boolean  @default(true)
  isArchived        Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  company           Company                   @relation(fields: [companyId], references: [id])
  userAccess        UserStoreAccess[]
  auditLogs         AuditLog[]
  settings          StoreSettings?
  documentSequences DocumentSequence[]
  debtTransactions  CustomerDebtTransaction[]
  inventoryCategories InventoryCategory[]
  products          Product[]
  parts             Part[]
  services          Service[]
  suppliers         Supplier[]
  purchaseInvoices  PurchaseInvoice[]
  purchaseOrders    PurchaseOrder[]
  stockBatches      StockBatch[]
  stockMovements    StockMovement[]
  repairTickets     RepairTicket[]
  estimates         Estimate[]
  customerApprovalLogs CustomerApprovalLog[]
  cashSessions      CashRegisterSession[]
  posSales          PosSale[]
  cashMovements     CashMovement[]
  repairInvoices    RepairInvoice[]
  refunds           Refund[]
  expenses                Expense[]
  expenseCategories       ExpenseCategory[]
  whatsappNotificationLogs WhatsAppNotificationLog[]

  @@unique([companyId, prefix])
  @@index([companyId])
  @@map("stores")
}

model UserStoreAccess {
  id      String @id @default(cuid())
  userId  String
  storeId String

  user  User  @relation(fields: [userId], references: [id])
  store Store @relation(fields: [storeId], references: [id])

  @@unique([userId, storeId])
  @@map("user_store_access")
}

model Plan {
  id           String   @id @default(cuid())
  name         String
  code         PlanCode @unique
  // null = unlimited stores (multi_store plan)
  maxStores    Int?
  featuresJson Json     @default("{}")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  subscriptions CompanySubscription[]

  @@map("plans")
}

model CompanySubscription {
  id          String             @id @default(cuid())
  companyId   String
  planId      String
  paymentModel PaymentModel      @default(yearly)
  status      SubscriptionStatus @default(trial)
  startedAt   DateTime           @default(now())
  // null = no expiry (lifetime plan)
  expiresAt   DateTime?
  // Set when status transitions active → grace
  graceEndsAt DateTime?
  // Lifetime plan only: maintenance contract expiry
  maintenanceExpiresAt DateTime?
  // ID of the SuperAdminUser who activated this subscription
  activatedBy String?
  note        String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  plan    Plan    @relation(fields: [planId], references: [id])

  @@index([companyId, status])
  @@map("company_subscriptions")
}

model TenantImpersonationSession {
  id               String    @id @default(cuid())
  superAdminUserId String
  companyId        String
  reason           String
  startedAt        DateTime  @default(now())
  // null = session still active
  endedAt          DateTime?

  superAdminUser SuperAdminUser @relation(fields: [superAdminUserId], references: [id])
  company        Company        @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@map("tenant_impersonation_sessions")
}

// Refresh token with family-based reuse detection and 2–3 second race grace window
model RefreshToken {
  id           String    @id @default(cuid())
  userId       String
  tokenHash    String    @unique
  // All tokens in a rotation chain share the same familyId; reuse in family = revoke all
  familyId     String
  expiresAt    DateTime
  isRevoked    Boolean   @default(false)
  replacedById String?
  replacedAt   DateTime?
  createdAt    DateTime  @default(now())
  createdIp    String?

  user           User           @relation(fields: [userId], references: [id])
  replacedBy     RefreshToken?  @relation("TokenChain", fields: [replacedById], references: [id])
  replacedTokens RefreshToken[] @relation("TokenChain")

  @@index([userId])
  @@index([tokenHash])
  @@index([familyId])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────────────────────────────────────
// CUSTOMERS  (company-scoped — shared across all stores in a company)
// ─────────────────────────────────────────────────────────────────────────────

model CustomerGroup {
  id                     String   @id @default(cuid())
  companyId              String
  name                   String
  // Warning threshold — never a hard block
  debtAlertLimit         Decimal? @db.Decimal(12, 2)
  defaultDiscountPercent Decimal  @default(0) @db.Decimal(5, 2)
  isArchived             Boolean  @default(false)
  createdAt              DateTime @default(now())

  company   Company    @relation(fields: [companyId], references: [id])
  customers Customer[]

  @@index([companyId])
  @@map("customer_groups")
}

model Customer {
  id                     String             @id @default(cuid())
  companyId              String
  customerType           CustomerType       @default(named)
  name                   String
  customerGroupId        String?
  languagePreference     LanguagePreference @default(fr)
  // Per-customer override of the group debt alert limit
  debtAlertLimitOverride Decimal?           @db.Decimal(12, 2)
  cnasNumber             String?
  casnosNumber           String?
  address                String?
  // ISO 3166-2:DZ wilaya code (01-58)
  wilayaCode             String?
  notes                  String?
  isArchived             Boolean            @default(false)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  company          Company                   @relation(fields: [companyId], references: [id])
  customerGroup    CustomerGroup?            @relation(fields: [customerGroupId], references: [id])
  phones           CustomerPhone[]
  assets           CustomerAsset[]
  debtBalance      CustomerDebtBalance?
  debtTransactions CustomerDebtTransaction[]
  repairTickets    RepairTicket[]
  posSales         PosSale[]
  repairInvoices   RepairInvoice[]

  @@index([companyId, customerType, isArchived])
  @@map("customers")
}

// Phone uniqueness is enforced per company via @@unique([companyId, phoneNumber])
// companyId is denormalized here to make that constraint possible at the DB level
model CustomerPhone {
  id          String   @id @default(cuid())
  customerId  String
  // Denormalized from customer.companyId — enables the unique-per-company constraint
  companyId   String
  phoneNumber String
  isPrimary   Boolean  @default(false)
  note        String?
  createdAt   DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id])
  company  Company  @relation(fields: [companyId], references: [id])

  // Core business rule: phone unique per company (across all customers)
  @@unique([companyId, phoneNumber])
  @@index([phoneNumber])
  @@map("customer_phones")
}

// Devices owned by a customer — used to autofill ticket creation
model CustomerAsset {
  id                  String   @id @default(cuid())
  customerId          String
  // FK to catalog tables (Block 6)
  deviceCategoryId    String?
  deviceBrandId       String?
  deviceModelFamilyId String?
  // Free-text device type for Block 5 display (e.g. "phone", "laptop"). Kept for backward compat.
  deviceTypeName      String?
  customBrand         String?
  customModel         String?
  imeiSerial          String?
  color               String?
  storage             String?
  notes               String?
  isArchived          Boolean  @default(false)
  createdAt           DateTime @default(now())

  customer          Customer           @relation(fields: [customerId], references: [id])
  deviceCategory    DeviceCategory?    @relation(fields: [deviceCategoryId], references: [id], onDelete: SetNull)
  deviceBrand       DeviceBrand?       @relation(fields: [deviceBrandId], references: [id], onDelete: SetNull)
  deviceModelFamily DeviceModelFamily? @relation(fields: [deviceModelFamilyId], references: [id], onDelete: SetNull)
  repairTickets     RepairTicket[]

  @@index([customerId])
  @@map("customer_assets")
}

// ─────────────────────────────────────────────────────────────────────────────
// DEVICE CATALOG  (global defaults + store custom entries)
// ─────────────────────────────────────────────────────────────────────────────

// Device type category (phone, tablet, laptop, desktop, printer, console, other)
model DeviceCategory {
  id        String   @id @default(cuid())
  key       String   @unique
  nameFr    String
  nameAr    String
  nameEn    String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  brands         DeviceBrand[]
  customerAssets CustomerAsset[]
  compatibleParts Part[]
  repairTickets  RepairTicket[]

  @@index([isActive, sortOrder])
  @@map("device_categories")
}

// Device brand (Apple, Samsung, …) — scoped to a category
// Global defaults: companyId/storeId = null, isGlobalDefault = true
// Store custom: companyId + storeId filled, isGlobalDefault = false
model DeviceBrand {
  id              String   @id @default(cuid())
  categoryId      String
  // null = global default; filled = tenant custom entry
  companyId       String?
  storeId         String?
  name            String
  sortOrder       Int      @default(0)
  isGlobalDefault Boolean  @default(false)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  category       DeviceCategory      @relation(fields: [categoryId], references: [id])
  modelFamilies  DeviceModelFamily[]
  customerAssets CustomerAsset[]
  compatibleParts Part[]
  repairTickets  RepairTicket[]

  @@unique([categoryId, companyId, storeId, name])
  @@index([categoryId, isActive, sortOrder])
  @@map("device_brands")
}

// Device model family (Galaxy A, iPhone 13, ThinkPad, …) — grouped under a brand
// Global defaults: companyId/storeId = null, isGlobalDefault = true
// Store custom: companyId + storeId filled, isGlobalDefault = false
model DeviceModelFamily {
  id              String   @id @default(cuid())
  brandId         String
  // null = global default; filled = tenant custom entry
  companyId       String?
  storeId         String?
  name            String
  sortOrder       Int      @default(0)
  isGlobalDefault Boolean  @default(false)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  brand          DeviceBrand     @relation(fields: [brandId], references: [id])
  customerAssets CustomerAsset[]
  compatibleParts Part[]
  repairTickets  RepairTicket[]

  @@unique([brandId, companyId, storeId, name])
  @@index([brandId, isActive, sortOrder])
  @@map("device_model_families")
}


model DeviceCatalogSuggestion {
  id               String                  @id @default(cuid())
  companyId        String
  storeId          String?
  createdByUserId  String?
  categoryId       String?
  categoryKey      String?
  brandId          String?
  brandName        String?
  familyId         String?
  printerType      String?
  seriesName       String?
  modelLine        String?
  generation       String?
  modelName        String
  processor        String?
  ram              String?
  storage          String?
  gpu              String?
  sku              String?
  notes            String?
  source           String                  @default("repair_intake")
  status           CatalogSuggestionStatus @default(pending)
  approvedFamilyId String?
  rejectionReason  String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  reviewedAt       DateTime?
  reviewedByUserId String?

  @@index([companyId, storeId, status, createdAt])
  @@index([categoryId, brandId, status])
  @@map("device_catalog_suggestions")
}

// Denormalized balance — source of truth is customer_debt_transactions
// Reconciled by cron every 6 hours; application always reads this for display
model CustomerDebtBalance {
  id         String   @id @default(cuid())
  customerId String   @unique
  repairDebt Decimal  @default(0) @db.Decimal(12, 2)
  saleDebt   Decimal  @default(0) @db.Decimal(12, 2)
  manualDebt Decimal  @default(0) @db.Decimal(12, 2)
  // totalDebt = repairDebt + saleDebt + manualDebt (maintained by app + reconciliation cron)
  totalDebt  Decimal  @default(0) @db.Decimal(12, 2)
  updatedAt  DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id])

  @@map("customer_debt_balances")
}

// Immutable ledger — never edited; corrections create new rows
// invoiceId and paymentId FKs added in Block 11 when those tables are created
model CustomerDebtTransaction {
  id         String              @id @default(cuid())
  customerId String
  // null for company-level adjustments (manual_debt type)
  storeId    String?
  type       DebtTransactionType
  direction  DebtDirection
  amount     Decimal             @db.Decimal(12, 2)
  // FK to invoices table — added in Block 11
  invoiceId  String?
  // FK to payments table — added in Block 11
  paymentId  String?
  note       String?
  createdAt  DateTime            @default(now())
  // User id who created this transaction (plain String — no FK to avoid cycles)
  createdBy  String

  customer Customer @relation(fields: [customerId], references: [id])
  store    Store?   @relation(fields: [storeId], references: [id])

  @@index([customerId, createdAt(sort: Desc)])
  @@map("customer_debt_transactions")
}

// ─────────────────────────────────────────────────────────────────────────────
// AUDIT LOG  (immutable — no edits, no deletes)
// ─────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id               String   @id @default(cuid())
  companyId        String
  // null for company-level events (user management, subscription changes)
  storeId          String?
  // null when action is performed by super admin
  userId           String?
  // null when action is performed by tenant user
  superAdminUserId String?
  action           String
  entityType       String
  entityId         String
  changedFieldsJson Json?
  ipAddress        String?
  userAgent        String?
  createdAt        DateTime @default(now())

  company        Company         @relation(fields: [companyId], references: [id])
  store          Store?          @relation(fields: [storeId], references: [id])
  user           User?           @relation(fields: [userId], references: [id])
  superAdminUser SuperAdminUser? @relation(fields: [superAdminUserId], references: [id])

  @@index([companyId, createdAt(sort: Desc)])
  @@index([entityType, entityId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// STORE SETTINGS  (one row per store — explicit columns for type safety)
// ─────────────────────────────────────────────────────────────────────────────

model StoreSettings {
  id      String @id @default(cuid())
  storeId String @unique

  // Document numbering
  ticketNumberFormat String @default("PREFIX-YYYY-MM-NNNN")

  // Repair defaults
  warrantyDaysDefault Int @default(30)

  // Abandoned device workflow thresholds (days)
  abandonedDeviceNoticeDays    Int @default(14)
  abandonedDeviceThresholdDays Int @default(30)

  // Operational thresholds
  pickupOverdueDays            Int     @default(7)
  lowStockDefaultThreshold     Int     @default(5)
  // Cashier can apply discounts up to this % without manager PIN
  cashierDiscountThresholdPct  Decimal @default(5) @db.Decimal(5, 2)
  // Refunds above this amount require Manager
  refundApprovalThreshold      Decimal @default(10000) @db.Decimal(12, 2)
  // Stock adjustments above this amount require Admin approval
  highValueAdjustmentThreshold Decimal @default(50000) @db.Decimal(12, 2)

  // WhatsApp
  whatsappPhone     String?
  whatsappOnPosSale Boolean @default(false)

  // Display
  currencyDisplay String @default("DZD")

  updatedAt DateTime @updatedAt
  // User id who last updated (plain String — no FK to avoid cycles with User table)
  updatedBy String?

  store Store @relation(fields: [storeId], references: [id])

  @@map("store_settings")
}

// ─────────────────────────────────────────────────────────────────────────────
// DOCUMENT SEQUENCES  (advisory-locked increment for race-safe numbering)
// ─────────────────────────────────────────────────────────────────────────────

model DocumentSequence {
  id         String               @id @default(cuid())
  storeId    String
  type       DocumentSequenceType
  year       Int
  month      Int
  lastNumber Int                  @default(0)

  store Store @relation(fields: [storeId], references: [id])

  @@unique([storeId, type, year, month])
  @@map("document_sequences")
}

// ─────────────────────────────────────────────────────────────────────────────
// INVENTORY  (store-scoped — products, parts, services)
// ─────────────────────────────────────────────────────────────────────────────

// Shared category lookup for products and parts (not device catalog)
model InventoryCategory {
  id        String   @id @default(cuid())
  storeId   String
  name      String
  // "product" | "part" — which item type this category belongs to
  itemType  String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  products Product[]
  parts    Part[]

  store Store @relation(fields: [storeId], references: [id])

  @@unique([storeId, itemType, name])
  @@index([storeId, itemType, isActive])
  @@map("inventory_categories")
}

// Sellable product — chargers, cables, cases, accessories, etc.
// Store-scoped. No cost/FIFO fields in MVP.
model Product {
  id                String   @id @default(cuid())
  storeId           String
  categoryId        String?
  name              String
  // PRD-000001 style, unique per store
  sku               String
  barcode           String?
  brand             String?
  modelReference    String?
  sellingPrice      Decimal  @db.Decimal(12, 2)
  stockQty          Int      @default(0)
  lowStockThreshold Int?
  notes             String?
  imageUrl          String?
  isArchived        Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  store    Store              @relation(fields: [storeId], references: [id])
  category InventoryCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  purchaseInvoiceLines PurchaseInvoiceLine[]
  stockBatches         StockBatch[]
  stockMovements       StockMovement[]
  estimateLines        EstimateLine[]
  posSaleLines         PosSaleLine[]
  refundLines          RefundLine[]
  purchaseOrderLines  PurchaseOrderLine[]


  @@unique([storeId, sku])
  @@unique([storeId, barcode])
  @@index([storeId, isArchived])
  @@map("products")
}

// Repair part — screens, batteries, ports, cameras, etc.
// Store-scoped. Compatible with device catalog via optional FKs.
model Part {
  id                    String   @id @default(cuid())
  storeId               String
  categoryId            String?
  // Optional catalog compatibility fields
  compatibleCategoryId  String?
  compatibleBrandId     String?
  compatibleFamilyId    String?
  name                  String
  // PRT-000001 style, unique per store
  sku                   String
  barcode               String?
  brand                 String?
  modelReference        String?
  sellingPrice          Decimal  @db.Decimal(12, 2)
  stockQty              Int      @default(0)
  lowStockThreshold     Int?
  notes                 String?
  imageUrl              String?
  isArchived            Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  store               Store              @relation(fields: [storeId], references: [id])
  category            InventoryCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  compatibleCategory  DeviceCategory?    @relation(fields: [compatibleCategoryId], references: [id], onDelete: SetNull)
  compatibleBrand     DeviceBrand?       @relation(fields: [compatibleBrandId], references: [id], onDelete: SetNull)
  compatibleFamily    DeviceModelFamily? @relation(fields: [compatibleFamilyId], references: [id], onDelete: SetNull)
  purchaseInvoiceLines PurchaseInvoiceLine[]
  stockBatches         StockBatch[]
  stockMovements       StockMovement[]
  estimateLines        EstimateLine[]
  repairTicketParts    RepairTicketPart[]
  purchaseOrderLines    PurchaseOrderLine[]
  posSaleLines         PosSaleLine[]
  refundLines          RefundLine[]


  @@unique([storeId, sku])
  @@unique([storeId, barcode])
  @@index([storeId, isArchived])
  @@map("parts")
}

// Labor/service item — diagnosis, screen replacement labor, cleaning, etc.
// Store-scoped. No stock quantity.
model Service {
  id                      String   @id @default(cuid())
  storeId                 String
  name                    String
  // SRV-000001 style, unique per store
  sku                     String
  category                String?
  sellingPrice            Decimal  @db.Decimal(12, 2)
  estimatedDurationMinutes Int?
  notes                   String?
  isArchived              Boolean  @default(false)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id])
  estimateLines        EstimateLine[]
  posSaleLines         PosSaleLine[]
  refundLines          RefundLine[]


  @@unique([storeId, sku])
  @@index([storeId, isArchived])
  @@map("services")
}

// ─────────────────────────────────────────────────────────────────────────────
// PAYMENT METHODS  (seeded; cash-only for MVP — FK ready for V1.5 methods)
// ─────────────────────────────────────────────────────────────────────────────

model PaymentMethod {
  id        String  @id @default(cuid())
  code      String  @unique
  nameFr    String
  nameAr    String
  nameEn    String
  isActive  Boolean @default(true)
  isDefault Boolean @default(false)

  @@map("payment_methods")
}

// ─────────────────────────────────────────────────────────────────────────────
// SUPPLIERS & PURCHASES (Block 8)
// ─────────────────────────────────────────────────────────────────────────────

model Supplier {
  id         String   @id @default(cuid())
  companyId  String
  storeId    String
  name       String
  phone      String?
  address    String?
  notes      String?
  balance    Decimal  @db.Decimal(12, 2) @default(0)
  isArchived Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company         Company           @relation(fields: [companyId], references: [id])
  store           Store             @relation(fields: [storeId], references: [id])
  purchaseInvoices PurchaseInvoice[]
  purchaseOrders   PurchaseOrder[]

  @@index([storeId, isArchived])
  @@map("suppliers")
}

model PurchaseInvoice {
  id               String   @id @default(cuid())
  companyId        String
  storeId          String
  supplierId       String
  invoiceNumber    String
  invoiceDate      DateTime
  totalAmount      Decimal  @db.Decimal(12, 2)
  amountPaid       Decimal  @db.Decimal(12, 2) @default(0)
  remainingAmount  Decimal  @db.Decimal(12, 2)
  status           String   // unpaid, partial, paid
  notes            String?
  createdByUserId  String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  company   Company               @relation(fields: [companyId], references: [id])
  store     Store                 @relation(fields: [storeId], references: [id])
  supplier  Supplier              @relation(fields: [supplierId], references: [id])
  createdBy User                  @relation(fields: [createdByUserId], references: [id])
  lines     PurchaseInvoiceLine[]

  @@unique([storeId, invoiceNumber])
  @@index([storeId, status])
  @@map("purchase_invoices")
}

model PurchaseInvoiceLine {
  id                String   @id @default(cuid())
  purchaseInvoiceId String
  itemType          String   // "product" | "part"
  productId         String?
  partId            String?
  quantity          Int
  unitCost          Decimal  @db.Decimal(12, 2)
  totalCost         Decimal  @db.Decimal(12, 2)

  purchaseInvoice PurchaseInvoice @relation(fields: [purchaseInvoiceId], references: [id], onDelete: Cascade)
  product         Product?        @relation(fields: [productId], references: [id])
  part            Part?           @relation(fields: [partId], references: [id])

  @@map("purchase_invoice_lines")
}



model PurchaseOrder {
  id              String   @id @default(cuid())
  companyId       String
  storeId         String
  supplierId      String?
  orderNumber     String
  status          String   @default("draft") // draft | sent | confirmed | received | cancelled
  expectedAt      DateTime?
  subtotalAmount  Decimal  @default(0) @db.Decimal(12, 2)
  notes           String?
  sentAt          DateTime?
  receivedAt      DateTime?
  createdByUserId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company   Company              @relation(fields: [companyId], references: [id])
  store     Store                @relation(fields: [storeId], references: [id])
  supplier  Supplier?            @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  createdBy User                 @relation("PurchaseOrdersCreated", fields: [createdByUserId], references: [id])
  lines     PurchaseOrderLine[]

  @@unique([storeId, orderNumber])
  @@index([storeId, status])
  @@index([storeId, createdAt(sort: Desc)])
  @@map("purchase_orders")
}

model PurchaseOrderLine {
  id                 String   @id @default(cuid())
  purchaseOrderId    String
  itemType           String   // "product" | "part" | "custom"
  productId          String?
  partId             String?
  description        String
  quantity           Int
  unitCost           Decimal  @default(0) @db.Decimal(12, 2)
  totalCost          Decimal  @default(0) @db.Decimal(12, 2)
  suggestedFromStock Boolean  @default(false)
  createdAt          DateTime @default(now())

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)
  part          Part?         @relation(fields: [partId], references: [id], onDelete: SetNull)

  @@index([purchaseOrderId])
  @@map("purchase_order_lines")
}

// ─────────────────────────────────────────────────────────────────────────────
// STOCK & FIFO BATCHES (Block 8)
// ─────────────────────────────────────────────────────────────────────────────

model StockBatch {
  id             String   @id @default(cuid())
  companyId      String
  storeId        String
  itemType       String   // "product" | "part"
  productId      String?
  partId         String?
  sourceType     String   // "purchase_invoice" | "adjustment" | "return" | "opening_balance"
  sourceId       String?
  qtyInitial     Int
  qtyRemaining   Int
  unitCost       Decimal  @db.Decimal(12, 2)
  createdAt      DateTime @default(now())

  company   Company         @relation(fields: [companyId], references: [id])
  store     Store           @relation(fields: [storeId], references: [id])
  product   Product?        @relation(fields: [productId], references: [id])
  part      Part?           @relation(fields: [partId], references: [id])
  movements StockMovement[]

  @@index([storeId, itemType, qtyRemaining])
  @@map("stock_batches")
}

model StockMovement {
  id               String   @id @default(cuid())
  companyId        String
  storeId          String
  itemType         String   // "product" | "part"
  productId        String?
  partId           String?
  movementType     String   // "purchase" | "adjustment_in" | "adjustment_out" | "return" | "correction"
  quantityDelta    Int
  unitCostSnapshot Decimal? @db.Decimal(12, 2)
  stockBatchId     String?
  sourceType       String?
  sourceId         String?
  note             String?
  createdByUserId  String
  createdAt        DateTime @default(now())

  company   Company     @relation(fields: [companyId], references: [id])
  store     Store       @relation(fields: [storeId], references: [id])
  product   Product?    @relation(fields: [productId], references: [id])
  part      Part?       @relation(fields: [partId], references: [id])
  batch     StockBatch? @relation(fields: [stockBatchId], references: [id])
  createdBy User        @relation(fields: [createdByUserId], references: [id])

  @@index([storeId, itemType])
  @@map("stock_movements")
}

// ─────────────────────────────────────────────────────────────────────────────
// REPAIRS (Block 9)
// ─────────────────────────────────────────────────────────────────────────────

model RepairTicket {
  id                  String         @id @default(cuid())
  companyId           String
  storeId             String
  ticketNumber        String
  customerId          String
  customerDeviceId    String?
  deviceCategoryId    String?
  deviceBrandId       String?
  deviceFamilyId      String?
  customDeviceBrand   String?
  customDeviceModel   String?
  deviceColor         String?
  deviceStorageRam    String?
  imeiSerial          String?
  currentStatus       RepairStatus   @default(received)
  priority            RepairPriority @default(normal)
  assignedTechnicianId String?
  diagnosisNote       String?
  internalNotes       String?
  customerNotes       String?
  estimatedPrice      Decimal?       @db.Decimal(12, 2)
  finalPrice          Decimal?       @db.Decimal(12, 2)
  warrantyDays        Int?
  dueAt               DateTime?
  isArchived          Boolean        @default(false)
  createdByUserId     String
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  company             Company              @relation(fields: [companyId], references: [id])
  store               Store                @relation(fields: [storeId], references: [id])
  customer            Customer             @relation(fields: [customerId], references: [id])
  customerDevice      CustomerAsset?       @relation(fields: [customerDeviceId], references: [id], onDelete: SetNull)
  deviceCategory      DeviceCategory?      @relation(fields: [deviceCategoryId], references: [id], onDelete: SetNull)
  deviceBrand         DeviceBrand?         @relation(fields: [deviceBrandId], references: [id], onDelete: SetNull)
  deviceFamily        DeviceModelFamily?   @relation(fields: [deviceFamilyId], references: [id], onDelete: SetNull)
  assignedTechnician  User?                @relation("AssignedRepairs", fields: [assignedTechnicianId], references: [id])
  createdBy           User                 @relation("CreatedRepairs", fields: [createdByUserId], references: [id])
  
  problems            RepairTicketProblem[]
  statusHistory       RepairStatusHistory[]
  estimates           Estimate[]
  approvalLogs        CustomerApprovalLog[]
  reservedParts       RepairTicketPart[]
  repairInvoices      RepairInvoice[]

  @@unique([storeId, ticketNumber])
  @@index([storeId, currentStatus])
  @@index([customerId])
  @@index([assignedTechnicianId])
  @@map("repair_tickets")
}

model RepairTicketProblem {
  id               String                  @id @default(cuid())
  repairTicketId   String
  problemText      String
  resolutionStatus ProblemResolutionStatus @default(pending)
  createdAt        DateTime                @default(now())

  repairTicket     RepairTicket            @relation(fields: [repairTicketId], references: [id], onDelete: Cascade)

  @@index([repairTicketId])
  @@map("repair_ticket_problems")
}

model RepairStatusHistory {
  id               String       @id @default(cuid())
  repairTicketId   String
  oldStatus        RepairStatus?
  newStatus        RepairStatus
  changedByUserId  String
  note             String?
  createdAt        DateTime     @default(now())

  repairTicket     RepairTicket @relation(fields: [repairTicketId], references: [id], onDelete: Cascade)
  changedBy        User         @relation(fields: [changedByUserId], references: [id])

  @@index([repairTicketId, createdAt(sort: Desc)])
  @@map("repair_status_history")
}

// ─────────────────────────────────────────────────────────────────────────────
// ESTIMATES & DEVIS
// ─────────────────────────────────────────────────────────────────────────────

model Estimate {
  id              String         @id @default(cuid())
  companyId       String
  storeId         String
  repairTicketId  String
  estimateNumber  String
  status          EstimateStatus @default(draft)
  subtotalAmount  Float
  discountAmount  Float          @default(0)
  totalAmount     Float
  customerNote    String?
  internalNote    String?
  sentAt          DateTime?
  acceptedAt      DateTime?
  rejectedAt      DateTime?
  publicApprovalToken     String?   @unique
  publicApprovalExpiresAt DateTime?
  publicDecisionIp        String?
  publicDecisionUserAgent String?
  createdByUserId String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  company         Company        @relation(fields: [companyId], references: [id])
  store           Store          @relation(fields: [storeId], references: [id])
  repairTicket    RepairTicket   @relation(fields: [repairTicketId], references: [id])
  createdBy       User           @relation(fields: [createdByUserId], references: [id])
  lines           EstimateLine[]
  approvalLogs    CustomerApprovalLog[]

  @@unique([storeId, estimateNumber])
  @@index([repairTicketId])
  @@map("estimates")
}

model EstimateLine {
  id              String           @id @default(cuid())
  estimateId      String
  lineType        EstimateLineType
  description     String
  productId       String?
  partId          String?
  serviceId       String?
  quantity        Float
  unitPrice       Float
  totalPrice      Float
  sortOrder       Int              @default(0)
  createdAt       DateTime         @default(now())

  estimate        Estimate         @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  product         Product?         @relation(fields: [productId], references: [id])
  part            Part?            @relation(fields: [partId], references: [id])
  service         Service?         @relation(fields: [serviceId], references: [id])

  @@index([estimateId])
  @@map("estimate_lines")
}

model CustomerApprovalLog {
  id                  String                 @id @default(cuid())
  companyId           String
  storeId             String
  repairTicketId      String
  estimateId          String?
  decision            String // "accepted" or "rejected"
  confirmationMethod  CustomerApprovalMethod
  confirmedByUserId   String
  note                String?
  createdAt           DateTime               @default(now())

  company         Company        @relation(fields: [companyId], references: [id])
  store           Store          @relation(fields: [storeId], references: [id])
  repairTicket    RepairTicket   @relation(fields: [repairTicketId], references: [id])
  estimate        Estimate?      @relation(fields: [estimateId], references: [id])
  confirmedBy     User           @relation(fields: [confirmedByUserId], references: [id])

  @@index([repairTicketId])
  @@map("customer_approval_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// REPAIR TICKET PARTS (Stock Reservation — Block 11)
// ─────────────────────────────────────────────────────────────────────────────

model RepairTicketPart {
  id                String           @id @default(cuid())
  companyId         String
  storeId           String
  repairTicketId    String
  partId            String
  quantity          Int
  status            RepairPartStatus @default(reserved)
  reservedByUserId  String
  releasedByUserId  String?
  releasedAt        DateTime?
  note              String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  repairTicket      RepairTicket     @relation(fields: [repairTicketId], references: [id])
  part              Part             @relation(fields: [partId], references: [id])
  reservedBy        User             @relation("ReservedByUser", fields: [reservedByUserId], references: [id])
  releasedBy        User?            @relation("ReleasedByUser", fields: [releasedByUserId], references: [id])

  @@index([repairTicketId])
  @@index([partId])
  @@index([storeId, partId, status])
  @@index([companyId, storeId])
  @@map("repair_ticket_parts")
}

// ─────────────────────────────────────────────────────────────────────────────
// CASH REGISTER SESSIONS (Block 12)
// ─────────────────────────────────────────────────────────────────────────────

model CashRegisterSession {
  id                  String            @id @default(cuid())
  companyId           String
  storeId             String
  openedByUserId      String
  closedByUserId      String?
  forceClosedByUserId String?
  status              CashSessionStatus @default(opened)
  openingCashAmount   Decimal           @db.Decimal(12, 2)
  expectedCashAmount  Decimal           @default(0) @db.Decimal(12, 2)
  countedCashAmount   Decimal?          @db.Decimal(12, 2)
  varianceAmount      Decimal?          @db.Decimal(12, 2)
  openedAt            DateTime          @default(now())
  closedAt            DateTime?
  forceCloseNote      String?
  notes               String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  company             Company           @relation(fields: [companyId], references: [id])
  store               Store             @relation(fields: [storeId], references: [id])
  openedBy            User              @relation("CashSessionOpenedBy", fields: [openedByUserId], references: [id])
  closedBy            User?             @relation("CashSessionClosedBy", fields: [closedByUserId], references: [id])
  forceClosedBy       User?             @relation("CashSessionForceClosedBy", fields: [forceClosedByUserId], references: [id])
  posSales            PosSale[]
  cashMovements       CashMovement[]
  refunds             Refund[]
  expenses            Expense[]


  @@index([storeId, status])
  @@index([companyId, storeId])
  @@map("cash_register_sessions")
}

// ─────────────────────────────────────────────────────────────────────────────
// POS SALES (Block 13)
// ─────────────────────────────────────────────────────────────────────────────

model PosSale {
  id                 String        @id @default(cuid())
  companyId          String
  storeId            String
  saleNumber         String
  customerId         String?
  cashSessionId      String
  subtotalAmount     Decimal       @db.Decimal(12, 2)
  discountAmount     Decimal       @default(0) @db.Decimal(12, 2)
  totalAmount        Decimal       @db.Decimal(12, 2)
  cashReceivedAmount Decimal       @db.Decimal(12, 2)
  changeAmount       Decimal       @db.Decimal(12, 2)
  debtAmount         Decimal       @default(0) @db.Decimal(12, 2)
  status             PosSaleStatus @default(completed)
  createdByUserId    String
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  company     Company              @relation(fields: [companyId], references: [id])
  store       Store                @relation(fields: [storeId], references: [id])
  customer    Customer?            @relation(fields: [customerId], references: [id])
  cashSession CashRegisterSession  @relation(fields: [cashSessionId], references: [id])
  createdBy   User                 @relation(fields: [createdByUserId], references: [id])
  lines       PosSaleLine[]
  refunds     Refund[]


  @@unique([storeId, saleNumber])
  @@index([storeId, createdAt(sort: Desc)])
  @@index([cashSessionId])
  @@map("pos_sales")
}

model PosSaleLine {
  id          String   @id @default(cuid())
  posSaleId   String
  lineType    String   // "product" | "part" | "service"
  productId   String?
  partId      String?
  serviceId   String?
  description String
  quantity    Int
  unitPrice   Decimal  @db.Decimal(12, 2)
  totalPrice  Decimal  @db.Decimal(12, 2)
  costTotal   Decimal? @db.Decimal(12, 2)
  createdAt   DateTime @default(now())

  posSale     PosSale  @relation(fields: [posSaleId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id])
  part        Part?    @relation(fields: [partId], references: [id])
  service     Service? @relation(fields: [serviceId], references: [id])
  refundLines RefundLine[]

  @@index([posSaleId])
  @@map("pos_sale_lines")
}

// ─────────────────────────────────────────────────────────────────────────────
// CASH MOVEMENTS (Block 13)
// ─────────────────────────────────────────────────────────────────────────────

model CashMovement {
  id                String                @id @default(cuid())
  companyId         String
  storeId           String
  cashSessionId     String
  movementType      CashMovementType
  direction         CashMovementDirection
  amount            Decimal               @db.Decimal(12, 2)
  sourceType        String?
  sourceId          String?
  note              String?
  createdByUserId   String
  createdAt         DateTime              @default(now())

  company     Company              @relation(fields: [companyId], references: [id])
  store       Store                @relation(fields: [storeId], references: [id])
  cashSession CashRegisterSession  @relation(fields: [cashSessionId], references: [id])
  createdBy   User                 @relation(fields: [createdByUserId], references: [id])

  @@index([cashSessionId])
  @@index([storeId, createdAt(sort: Desc)])
  @@map("cash_movements")
}

// ─────────────────────────────────────────────────────────────────────────────
// REPAIR INVOICES (Block 15)
// ─────────────────────────────────────────────────────────────────────────────

model RepairInvoice {
  id                String               @id @default(cuid())
  companyId         String
  storeId           String
  repairTicketId    String
  invoiceNumber     String
  customerId        String
  subtotalAmount    Decimal              @db.Decimal(12, 2)
  discountAmount    Decimal              @default(0) @db.Decimal(12, 2)
  totalAmount       Decimal              @db.Decimal(12, 2)
  paidAmount        Decimal              @default(0) @db.Decimal(12, 2)
  debtAmount        Decimal              @default(0) @db.Decimal(12, 2)
  refundedAmount    Decimal              @default(0) @db.Decimal(12, 2)
  status            RepairInvoiceStatus  @default(unpaid)
  createdByUserId   String
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  company      Company       @relation(fields: [companyId], references: [id])
  store        Store         @relation(fields: [storeId], references: [id])
  repairTicket RepairTicket  @relation(fields: [repairTicketId], references: [id])
  customer     Customer      @relation(fields: [customerId], references: [id])
  createdBy    User          @relation("RepairInvoicesCreated", fields: [createdByUserId], references: [id])
  lines        RepairInvoiceLine[]
  refunds      Refund[]


  @@unique([storeId, invoiceNumber])
  @@index([repairTicketId])
  @@index([customerId])
  @@index([storeId, createdAt(sort: Desc)])
  @@map("repair_invoices")
}

model RepairInvoiceLine {
  id                  String    @id @default(cuid())
  repairInvoiceId     String
  lineType            String    // "labor" | "part" | "service" | "custom"
  description         String
  repairTicketPartId  String?
  serviceId           String?
  quantity            Decimal   @db.Decimal(12, 3)
  unitPrice           Decimal   @db.Decimal(12, 2)
  totalPrice          Decimal   @db.Decimal(12, 2)
  costTotal           Decimal?  @db.Decimal(12, 2)
  createdAt           DateTime  @default(now())

  repairInvoice RepairInvoice @relation(fields: [repairInvoiceId], references: [id], onDelete: Cascade)
  refundLines   RefundLine[]

  @@index([repairInvoiceId])
  @@map("repair_invoice_lines")
}

// ─────────────────────────────────────────────────────────────────────────────
// REFUNDS (Block 16)
// ─────────────────────────────────────────────────────────────────────────────

enum RefundType {
  pos_sale
  repair_invoice
}

enum RefundStatus {
  completed
  cancelled
}

model Refund {
  id                  String       @id @default(cuid())
  companyId           String
  storeId             String
  refundNumber        String
  refundType          RefundType
  posSaleId           String?
  repairInvoiceId     String?
  cashSessionId       String
  totalRefundAmount   Decimal      @db.Decimal(12, 2)
  reason              String
  status              RefundStatus @default(completed)
  createdByUserId     String
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  company       Company             @relation(fields: [companyId], references: [id])
  store         Store               @relation(fields: [storeId], references: [id])
  posSale       PosSale?            @relation(fields: [posSaleId], references: [id])
  repairInvoice RepairInvoice?      @relation(fields: [repairInvoiceId], references: [id])
  cashSession   CashRegisterSession @relation(fields: [cashSessionId], references: [id])
  createdBy     User                @relation(fields: [createdByUserId], references: [id])
  lines         RefundLine[]

  @@unique([storeId, refundNumber])
  @@index([posSaleId])
  @@index([repairInvoiceId])
  @@index([storeId, createdAt(sort: Desc)])
  @@map("refunds")
}

model RefundLine {
  id                    String   @id @default(cuid())
  refundId              String
  lineType              String   // "product" | "part" | "service" | "labor" | "custom"
  posSaleLineId         String?
  repairInvoiceLineId   String?
  productId             String?
  partId                String?
  serviceId             String?
  description           String
  quantity              Decimal  @db.Decimal(12, 3)
  unitPrice             Decimal  @db.Decimal(12, 2)
  totalRefundAmount     Decimal  @db.Decimal(12, 2)
  createdAt             DateTime @default(now())

  refund            Refund             @relation(fields: [refundId], references: [id], onDelete: Cascade)
  posSaleLine       PosSaleLine?       @relation(fields: [posSaleLineId], references: [id])
  repairInvoiceLine RepairInvoiceLine? @relation(fields: [repairInvoiceLineId], references: [id])
  product           Product?           @relation(fields: [productId], references: [id])
  part              Part?              @relation(fields: [partId], references: [id])
  service           Service?           @relation(fields: [serviceId], references: [id])

  @@index([refundId])
  @@map("refund_lines")
}

// ─────────────────────────────────────────────────────────────────────────────
// EXPENSES (Block 18)
// ─────────────────────────────────────────────────────────────────────────────

model ExpenseCategory {
  id        String    @id @default(cuid())
  storeId   String?   // null for global
  name      String
  isDefault Boolean   @default(false)
  expenses  Expense[]
  store     Store?    @relation(fields: [storeId], references: [id])

  @@map("expense_categories")
}

model Expense {
  id                String   @id @default(cuid())
  storeId           String
  categoryId        String
  amount            Decimal  @db.Decimal(12, 2)
  expenseDate       DateTime @default(now())
  note              String?
  cashSessionId     String?
  createdByUserId   String
  createdAt         DateTime @default(now())

  store             Store                @relation(fields: [storeId], references: [id])
  category          ExpenseCategory      @relation(fields: [categoryId], references: [id])
  cashSession       CashRegisterSession? @relation(fields: [cashSessionId], references: [id])
  createdBy         User                 @relation("ExpensesCreated", fields: [createdByUserId], references: [id])

  @@index([storeId])
  @@index([expenseDate])
  @@map("expenses")
}

// ─────────────────────────────────────────────────────────────────────────────
// WHATSAPP NOTIFICATION LOG  (immutable audit trail of wa.me messages opened)
// ─────────────────────────────────────────────────────────────────────────────

model WhatsAppNotificationLog {
  id             String   @id @default(cuid())
  storeId        String
  // null for walk-in or when customer record not known
  customerId     String?
  entityType     String   // 'repair_ticket' | 'repair_invoice' | 'pos_sale' | 'test'
  entityId       String
  phone          String
  // First 200 chars of message for display in log
  messagePreview String
  sentByUserId   String
  createdAt      DateTime @default(now())

  store Store @relation(fields: [storeId], references: [id])

  @@index([storeId, createdAt(sort: Desc)])
  @@index([entityType, entityId])
  @@map("whatsapp_notification_logs")
}
